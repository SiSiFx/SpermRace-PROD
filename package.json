{
	"name": "spermrace.io",
	"version": "1.0.0",
	"description": "Spermatozoide battle royale multiplayer game with crypto integration",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names \"server,client\" --prefix-colors \"blue,cyan\" \"pnpm --filter server dev\" \"pnpm --filter client dev\"",
    "dev:devnet": "concurrently --kill-others-on-fail --names \"server,client\" --prefix-colors \"blue,cyan\" \"pnpm --filter server dev:devnet\" \"pnpm --filter client dev\"",
    "dev:devnet:paid": "concurrently --kill-others-on-fail --names \"server,client\" --prefix-colors \"blue,cyan\" \"pnpm --filter server dev:devnet:paid\" \"pnpm --filter client dev\"",
    "dev:server": "pnpm --filter server dev",
    "dev:client": "pnpm --filter client dev",
    "start:server": "pnpm --filter server start",
    "start:client": "pnpm --filter client preview",
    "demo": "concurrently --kill-others-on-fail --names \"server,client\" --prefix-colors \"green,yellow\" \"pnpm --filter server dev:devnet\" \"pnpm --filter client demo\"",
    "smart:dev": "node smart-start.js dev",
    "cleanup": "powershell -ExecutionPolicy Bypass -File scripts/cleanup-ports.ps1",
    "build": "pnpm --filter shared build && pnpm --filter server build && pnpm --filter client build",
    "vercel-build": "pnpm --filter shared build && pnpm --filter client build",
    "build:server": "pnpm --filter server build",
    "build:client": "pnpm --filter client build",
    "start:prod": "pm2 start ops/pm2/ecosystem.config.js && pm2 save",
    "test": "node test-integration.js",
    "test:ws": "node scripts/loadtest/ws-regression-test.js",
    "test:ws:local": "node scripts/loadtest/ws-regression-test.js --url ws://127.0.0.1:8080/ws --clients 12 --seconds 35 --mode practice --tier 0",
    "loadtest:ws": "node scripts/loadtest/ws-broadcast.js ws://127.0.0.1:8080/ws 200 60",
    "test:mobile": "bash scripts/test-mobile.sh",
    "test:mobile:coverage": "bash scripts/test-mobile.sh --coverage",
    "test:mobile:ui": "bash scripts/test-mobile.sh --ui",
    "test:mobile:client": "pnpm --filter client test:mobile",
    "test:e2e:dev": "cross-env PLAYWRIGHT_BASE_URL=https://dev.spermrace.io pnpm exec playwright test -c playwright.remote.config.ts",
    "diagnose": "node frontend-diagnostic.js",
    "menu": "node interactive-menu.js",
    "install-all": "pnpm install && pnpm --filter core build && pnpm --filter shared build",
    "clean:artifacts": "python3 scripts/cleanup-local-artifacts.py",
    "clean:artifacts:apply": "python3 scripts/cleanup-local-artifacts.py --apply"
  },
	"devDependencies": {
		"@playwright/test": "1.56.1",
		"concurrently": "^8.2.2",
		"cross-env": "^7.0.3",
		"playwright": "1.56.1"
	},
	"dependencies": {
		"pnpm": "^10.13.1"
	},
	"pnpm": {
		"overrides": {
			"axios": "1.13.5",
			"minimatch": "10.2.1"
		}
	},
	"packageManager": "pnpm@9.15.9+sha512.68046141893c66fad01c079231128e9afb89ef87e2691d69e4d40eee228988295fd4682181bae55b58418c3a253bde65a505ec7c5f9403ece5cc3cd37dcf2531"
}
