NODE_ENV=production
PORT=8080
LOG_LEVEL=info

# CORS/WS origins
ALLOWED_ORIGINS=https://spermrace.io,https://www.spermrace.io

# Solana + payout
SOLANA_RPC_ENDPOINT=https://api.mainnet-beta.solana.com
PRIZE_POOL_WALLET=REPLACE_WITH_MAINNET_PRIZE_POOL_PUBLIC_KEY
PRIZE_POOL_SECRET_KEY=REPLACE_WITH_SECRET_MANAGER_VALUE

# Lobby settings
LOBBY_MAX_PLAYERS_TOURNAMENT=36
LOBBY_MAX_PLAYERS_PRACTICE=10
LOBBY_MIN_START=24
LOBBY_SURGE_RULES=30:16,60:8
ENABLE_PRACTICE_BOTS=true
PRACTICE_BOTS_TARGET=9

# Runtime controls
SKIP_ENTRY_FEE=false
ENABLE_DEV_BOTS=false

# Reverse proxy settings
TRUST_PROXY=1

# SIWS hardening
SIWS_DOMAINS=spermrace.io,www.spermrace.io
SIWS_NONCE_TTL_MS=60000
SIWS_CHALLENGE_TTL_MS=120000

# Ops endpoints (metrics/readyz details)
OPS_TOKEN=REPLACE_WITH_OPS_TOKEN_VALUE
OPS_ALLOW_LOCAL=1
