NODE_ENV=development
PORT=8080
LOG_LEVEL=info
LOG_JSON=false

# CORS/WS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5174

# Solana
SOLANA_RPC_ENDPOINT=https://api.devnet.solana.com
SKIP_ENTRY_FEE=true

# Dev bots
ENABLE_DEV_BOTS=true
DEV_BOTS_TARGET=8

# SIWS/session hardening
SIWS_DOMAINS=localhost
SIWS_NONCE_TTL_MS=60000
SIWS_CHALLENGE_TTL_MS=120000
SESSION_TOKEN_TTL_MS=300000
SESSION_TOKEN_BIND_IP=0

# Reverse proxy settings
TRUST_PROXY=0

# Ops endpoints (leave blank for local)
# OPS_TOKEN=REPLACE_WITH_OPS_TOKEN_VALUE
OPS_ALLOW_LOCAL=1
