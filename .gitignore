# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
dist.backup-*/
build/

# Environment variables
# Never track real env files; allow example templates
.env
.env.local
.env.*.local
.env.backup
*.env.production
*.env.staging
*.env.test
*.env
!*.env.example
!**/.env.example

# Logs
*.log
logs/
npm-debug.log*
pnpm-debug.log*

# OS files
.DS_Store
Thumbs.db
NUL

# IDE
.vscode/
.idea/
*.swp
*.swo

# Data
packages/server/data/*
# Some build paths nested server folder; ignore any data dirs under packages
packages/**/data/*
packages/server/packages/server/data/*

# PM2
.pm2/
pids/
*.pid
*.seed

# Temporary files
*.tmp
.cache/
.vercel

# Coverage artifacts
coverage/
**/coverage/
*.lcov
coverage-final.json

# Playwright artifacts
test-results/
playwright-report/
playwright-screenshots/

# Autonomous tmux artifacts
.autonomous/

# Test DB artifacts
packages/server/test-*.db*

# Vite timestamps
*.timestamp-*.mjs

# Codex scratch
scripts/loadtest/.codex_write_test

# Database files (production data - never commit)
data/
*.db
*.db-shm
*.db-wal

# Output/screenshot artifacts
output/
packages/client/output/
.env.backup
